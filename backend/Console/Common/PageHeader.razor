@using Microsoft.AspNetCore.Components

<div class="flex items-center gap-4 px-4 py-3 mb-4 border-b">
    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" @onclick="@(() => Navigation.NavigateTo("/"))">
        <LucideIcon Name="arrow-left" />
    </BbButton>
    <h1 class="text-2xl font-semibold">@Title</h1>
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;

    [Inject] private IConsoleNavigation Navigation { get; set; } = null!;
}
