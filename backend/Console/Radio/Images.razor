@page "/images"
@using global::Common
@using global::Meta.Images
@implements IDisposable

<PageTitle>Images</PageTitle>
@if (_isLoading)
{
    <div class="flex items-center justify-center py-16">
        <LucideIcon Name="loader-circle" Size="32" class="animate-spin text-primary" />
    </div>
    return;
}

<div class="images-page-shell @PageShellClass container mx-auto px-4 py-3 flex flex-col gap-3">
    <div class="images-toolbar rounded-lg border bg-card px-4 py-3 flex flex-wrap items-center gap-3">
        <div class="flex items-center gap-3">
            <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" @onclick="NavigateHome">
                <LucideIcon Name="arrow-left" Size="18" />
            </BbButton>
            <div class="rounded-md bg-primary/10 p-2.5">
                <LucideIcon Name="image" Size="20" class="text-primary" />
            </div>
            <div>
                <div class="text-lg font-semibold leading-tight">Images (@_images.Count)</div>
                <div class="text-xs text-muted-foreground">@_images.Count image(s) in media storage</div>
            </div>
        </div>
        <div class="flex-1"></div>
        @if (_isSelectionMode)
        {
            <div class="rounded-md bg-primary/10 px-3 py-1.5 text-xs font-medium text-primary">
                @_selectedImageKeys.Count selected
            </div>
            <BbButton Variant="ButtonVariant.Outline" Disabled="@(!HasSelection)" @onclick="DownloadSelection">
                <LucideIcon Name="download" Size="16" class="mr-2" />
                Download
            </BbButton>
            <BbButton Variant="ButtonVariant.Destructive" Disabled="@(!HasSelection)" @onclick="DeleteSelection">
                <LucideIcon Name="trash-2" Size="16" class="mr-2" />
                Delete
            </BbButton>
            <BbButton Variant="ButtonVariant.Ghost" @onclick="ExitSelectionMode">
                <LucideIcon Name="x" Size="16" class="mr-2" />
                Cancel
            </BbButton>
        }
        else
        {
            <BbButton Variant="ButtonVariant.Outline" Disabled="@(_images.Count == 0 || _isUploading || _isPasting)" @onclick="EnterSelectionMode">
                <LucideIcon Name="check" Size="16" class="mr-2" />
                Select
            </BbButton>
            <BbButton Variant="ButtonVariant.Outline" Disabled="@_isUploading" @onclick="RefreshImages">
                <LucideIcon Name="refresh-cw" Size="16" class="mr-2" />
                Refresh
            </BbButton>
            <BbButton Variant="ButtonVariant.Outline" Disabled="@(_isUploading || _isPasting)" @onclick="PasteImageUrl">
                @if (_isPasting)
                {
                    <LucideIcon Name="loader-circle" Size="16" class="mr-2 animate-spin" />
                    <span>Pasting...</span>
                }
                else
                {
                    <LucideIcon Name="clipboard" Size="16" class="mr-2" />
                    <span>Paste</span>
                }
            </BbButton>
            <BbButton Variant="ButtonVariant.Outline" Disabled="@(_images.Count == 0)" @onclick="DownloadAll">
                <LucideIcon Name="archive" Size="16" class="mr-2" />
                Download all
            </BbButton>
            <BbButton Disabled="@(_isUploading || _isPasting)" @onclick="OpenUpload">
                <LucideIcon Name="upload" Size="16" class="mr-2" />
                Upload
            </BbButton>
        }
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="rounded-lg border border-destructive/30 bg-destructive/10 p-3 text-sm text-destructive">
            @_error
        </div>
    }

    @if (_images.Count == 0)
    {
        <div class="rounded-lg border bg-card p-10 text-center text-sm text-muted-foreground">
            No images yet. Click <strong>Upload</strong> to add individual images or a folder.
        </div>
    }
    else
    {
        <div class="images-grid">
            @foreach (var image in _pageImages)
            {
                <ImageGridItem @key="image.Key"
                               Image="@image"
                               ImageUrl="@GetImageUrl(image)"
                               IsSelectionMode="@_isSelectionMode"
                               IsSelected="@_selectedImageKeys.Contains(image.Key)"
                               OnOpen="OpenPreview"
                               OnToggleSelected="ToggleImageSelected" />
            }
        </div>

        <div class="flex flex-wrap items-center justify-between gap-3 rounded-lg border bg-card px-4 py-3">
            <div class="flex flex-wrap items-center gap-3">
                <div class="text-xs text-muted-foreground">
                    Showing @PageStart-@PageEnd of @_images.Count, @_pageSize per page
                </div>
                <label class="flex items-center gap-2 text-xs text-muted-foreground">
                    <span>Per page</span>
                    <select class="h-8 rounded-md border bg-background px-2 text-xs" value="@_pageSize" @onchange="OnPageSizeChanged">
                        @foreach (var size in PageSizes)
                        {
                            <option value="@size" selected="@(size == _pageSize)">@size</option>
                        }
                    </select>
                </label>
            </div>

            <div class="flex items-center gap-2">
                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon"
                          Disabled="@(_page == 0)" @onclick="PrevPage">
                    <LucideIcon Name="chevron-left" Size="16" />
                </BbButton>
                <span class="text-xs text-muted-foreground px-2">@(_page + 1) / @_totalPages</span>
                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon"
                          Disabled="@(_page >= _totalPages - 1)" @onclick="NextPage">
                    <LucideIcon Name="chevron-right" Size="16" />
                </BbButton>
            </div>
        </div>
    }
</div>

@if (_isUploadOpen)
{
    <div class="image-upload-overlay fixed inset-0 z-50 flex items-center justify-center p-4" @onclick="CloseUpload">
        <div class="w-full max-w-2xl rounded-lg border bg-card shadow-lg" @onclick:stopPropagation>
            <div class="flex items-start justify-between gap-4 border-b p-4">
                <div class="flex items-center gap-3">
                    <div class="rounded-md bg-primary/10 p-2">
                        <LucideIcon Name="images" Size="18" class="text-primary" />
                    </div>
                    <div>
                        <h2 class="text-sm font-semibold">Upload images</h2>
                        <p class="text-xs text-muted-foreground">Drop images here, select files, or select a whole folder.</p>
                    </div>
                </div>
                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Disabled="@_isUploading" @onclick="CloseUpload">
                    <LucideIcon Name="x" Size="16" />
                </BbButton>
            </div>

            <div class="flex flex-col gap-3 p-4">
                <div class="relative rounded-lg border bg-background p-4 transition-all hover:border-primary/40 hover:bg-muted/30">
                    <div class="flex items-center gap-3">
                        <div class="rounded-md bg-primary/10 p-2.5">
                            <LucideIcon Name="upload" Size="18" class="text-primary" />
                        </div>
                        <div class="min-w-0 flex-1">
                            <div class="text-sm font-medium">Drag & drop images</div>
                            <div class="text-xs text-muted-foreground">Drop files on this row or click it to choose multiple images.</div>
                        </div>
                        <span class="text-xs text-muted-foreground">Files</span>
                    </div>
                    <input id="@FilesUploadInputId"
                           type="file"
                           multiple
                           accept="image/*"
                           disabled="@_isUploading"
                           class="absolute inset-0 h-full w-full cursor-pointer opacity-0" />
                </div>

                <div class="relative rounded-lg border bg-background p-4 transition-all hover:border-primary/40 hover:bg-muted/30">
                    <div class="flex items-center gap-3">
                        <div class="rounded-md bg-primary/10 p-2.5">
                            <LucideIcon Name="folder-up" Size="18" class="text-primary" />
                        </div>
                        <div class="min-w-0 flex-1">
                            <div class="text-sm font-medium">Upload a folder</div>
                            <div class="text-xs text-muted-foreground">Choose a directory; nested image files will be included by the browser.</div>
                        </div>
                        <span class="text-xs text-muted-foreground">Folder</span>
                    </div>
                    <input id="@FolderUploadInputId"
                           type="file"
                           multiple
                           accept="image/*"
                           webkitdirectory="webkitdirectory"
                           directory="directory"
                           disabled="@_isUploading"
                           class="absolute inset-0 h-full w-full cursor-pointer opacity-0" />
                </div>
            </div>

            <div class="flex flex-col gap-3 border-t px-4 py-3">
                @if (_isUploading || _uploadBytesTotal > 0)
                {
                    <div class="flex flex-col gap-1.5">
                        <div class="flex items-center justify-between gap-3 text-xs text-muted-foreground">
                            <div class="min-w-0 truncate">
                                @if (_isUploading)
                                {
                                    <LucideIcon Name="loader-circle" Size="14" class="mr-2 inline animate-spin" />
                                }
                                @_uploadStatus
                            </div>
                            <div class="shrink-0 font-mono">@UploadPercent.ToString("0")%</div>
                        </div>
                        <div class="h-2 overflow-hidden rounded-full bg-muted">
                            <div class="h-full rounded-full bg-primary transition-all duration-150" style="width: @UploadPercent%"></div>
                        </div>
                        <div class="flex items-center justify-between gap-3 text-[11px] text-muted-foreground">
                            <span class="min-w-0 truncate">@_uploadFileName</span>
                            <span class="shrink-0 font-mono">@FormatBytes(_uploadBytesDone) / @FormatBytes(_uploadBytesTotal)</span>
                        </div>
                    </div>
                }

                <div class="flex justify-end">
                    <BbButton Variant="ButtonVariant.Ghost" Disabled="@_isUploading" @onclick="CloseUpload">Close</BbButton>
                </div>
            </div>
        </div>
    </div>
}

@if (_selectedImage != null)
{
    <div class="image-preview-overlay fixed inset-0 z-50 flex items-center justify-center p-6" @onclick="ClosePreview">
        <div class="image-preview-panel" @onclick:stopPropagation>
            <div class="image-preview-header">
                <div class="flex min-w-0 items-center gap-3">
                    <div class="rounded-md bg-primary/10 p-2">
                        <LucideIcon Name="image" Size="18" class="text-primary" />
                    </div>
                    <div class="min-w-0">
                        <div class="truncate text-sm font-semibold">@_selectedImage.FileName</div>
                        <div class="text-xs text-muted-foreground">Full resolution preview</div>
                    </div>
                </div>
                <div class="flex shrink-0 items-center gap-2">
                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="DownloadSelected">
                        <LucideIcon Name="download" Size="14" class="mr-1" />
                        Download
                    </BbButton>
                    <BbButton Variant="ButtonVariant.Destructive" Size="ButtonSize.Small" @onclick="DeleteSelected">
                        <LucideIcon Name="trash-2" Size="14" class="mr-1" />
                        Delete
                    </BbButton>
                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" @onclick="ClosePreview">
                        <LucideIcon Name="x" Size="18" />
                    </BbButton>
                </div>
            </div>

            <div class="image-preview-body">
                <img src="@GetImageUrl(_selectedImage)"
                     alt="@_selectedImage.FileName"
                     class="image-preview-image" />
            </div>
        </div>
    </div>
}

<style>
    .images-page-shell {
        max-width: 108rem;
    }

    .images-page-shell--fixed {
        height: calc(100vh - 5.75rem);
        overflow: hidden;
    }

    .images-page-shell--scroll {
        min-height: calc(100vh - 5.75rem);
        overflow: visible;
    }

    .images-toolbar {
        flex: 0 0 auto;
    }

    .images-grid {
        display: grid;
        flex: 1 1 auto;
        min-height: 0;
        grid-template-columns: repeat(7, minmax(0, 1fr));
        gap: 0.5rem;
    }

    .images-page-shell--fixed .images-grid {
        grid-template-rows: repeat(3, minmax(0, 1fr));
    }

    .images-page-shell--scroll .images-grid {
        flex: 0 0 auto;
        grid-auto-rows: minmax(9rem, 13rem);
    }

    .image-grid-item {
        position: relative;
        display: flex;
        min-height: 0;
        height: 100%;
        flex-direction: column;
    }

    .image-grid-item--selected {
        border-color: hsl(var(--primary));
        box-shadow: 0 0 0 2px hsl(var(--primary) / 0.35);
    }

    .image-grid-item__selection {
        position: absolute;
        inset: 0.5rem auto auto 0.5rem;
        z-index: 2;
        display: flex;
        height: 1.75rem;
        width: 1.75rem;
        align-items: center;
        justify-content: center;
        border: 1px solid hsl(var(--border));
        border-radius: 9999px;
        background: hsl(var(--background) / 0.92);
        color: hsl(var(--muted-foreground));
        box-shadow: 0 6px 18px rgb(0 0 0 / 0.2);
    }

    .image-grid-item__selection--selected {
        border-color: hsl(var(--primary));
        background: hsl(var(--primary));
        color: hsl(var(--primary-foreground));
    }

    .image-grid-item__preview {
        min-height: 0;
        flex: 1 1 auto;
        overflow: hidden;
    }

    .image-grid-item__image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .image-grid-item__meta {
        flex: 0 0 auto;
    }

    .image-preview-overlay {
        background: rgb(0 0 0 / 0.72);
        backdrop-filter: blur(4px);
        cursor: zoom-out;
    }

    .image-upload-overlay {
        background: rgb(0 0 0 / 0.72);
        backdrop-filter: blur(4px);
    }

    .image-preview-panel {
        display: inline-flex;
        width: fit-content;
        max-width: calc(100vw - 3rem);
        max-height: calc(100vh - 3rem);
        flex-direction: column;
        overflow: hidden;
        border: 1px solid hsl(var(--border));
        border-radius: 0.75rem;
        background: hsl(var(--card));
        box-shadow: 0 30px 110px rgb(0 0 0 / 0.85);
        cursor: default;
    }

    .image-preview-header {
        display: flex;
        flex: 0 0 auto;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        border-bottom: 1px solid hsl(var(--border));
        padding: 0.75rem 1rem;
        background: hsl(var(--card));
    }

    .image-preview-body {
        display: flex;
        min-height: 0;
        flex: 1 1 auto;
        align-items: center;
        justify-content: center;
        background: rgb(0 0 0 / 0.35);
    }

    .image-preview-image {
        display: block;
        max-width: calc(100vw - 3rem);
        max-height: calc(100vh - 8.5rem);
        object-fit: contain;
    }

    @@media (max-width: 900px) {
        .images-page-shell {
            height: auto;
            overflow: visible;
        }

        .images-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .images-page-shell--fixed .images-grid,
        .images-page-shell--scroll .images-grid {
            grid-template-rows: none;
            grid-auto-rows: minmax(10rem, 14rem);
        }
    }
</style>

@code {
    [Inject] public required IImagesCollection Collection { get; init; }
    [Inject] public required IConsoleNavigation Navigation { get; init; }
    [Inject] public required IHttpClientFactory HttpClientFactory { get; init; }
    [Inject] public required IMediaStorage Storage { get; init; }
    [Inject] public required IJSRuntime JS { get; init; }
    [Inject] public required ToastService ToastService { get; init; }

    private const int DefaultPageSize = 21;
    private const int MaxUploadFiles = 10000;
    private const long MaxUploadFileSize = 250L * 1024L * 1024L;
    private const string FilesUploadInputId = "images-files-upload-input";
    private const string FolderUploadInputId = "images-folder-upload-input";
    private const string UploadEndpoint = "/console/media/images/upload";
    private static readonly int[] PageSizes = [21, 42, 63];

    private readonly HashSet<string> _selectedImageKeys = new(StringComparer.Ordinal);
    private List<MediaImage> _images = new();
    private List<MediaImage> _pageImages = new();
    private MediaImage? _selectedImage;
    private DotNetObjectReference<Images>? _uploadCallback;
    private bool _isLoading = true;
    private bool _isUploadOpen;
    private bool _isUploading;
    private bool _isPasting;
    private bool _isSelectionMode;
    private bool _uploadInputsRegistered;
    private string _uploadStatus = string.Empty;
    private string _uploadFileName = string.Empty;
    private string _error = string.Empty;
    private long _uploadBytesDone;
    private long _uploadBytesTotal;
    private int _pageSize = DefaultPageSize;
    private int _page;
    private int _totalPages = 1;

    private bool HasSelection => _selectedImageKeys.Count > 0;

    private string PageShellClass => _pageSize == DefaultPageSize
        ? "images-page-shell--fixed"
        : "images-page-shell--scroll";

    private double UploadPercent => _uploadBytesTotal == 0
        ? 0
        : Math.Clamp(_uploadBytesDone * 100.0 / _uploadBytesTotal, 0, 100);

    private int PageStart => _images.Count == 0 ? 0 : _page * _pageSize + 1;
    private int PageEnd => Math.Min(_images.Count, (_page + 1) * _pageSize);

    protected override async Task OnInitializedAsync()
    {
        await RefreshImages();
        _isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_isUploadOpen || _uploadInputsRegistered)
            return;

        _uploadCallback ??= DotNetObjectReference.Create(this);

        try
        {
            await JS.InvokeVoidAsync("registerImageUploadInput", FilesUploadInputId, UploadEndpoint, _uploadCallback, MaxUploadFileSize, MaxUploadFiles);
            await JS.InvokeVoidAsync("registerImageUploadInput", FolderUploadInputId, UploadEndpoint, _uploadCallback, MaxUploadFileSize, MaxUploadFiles);
            _uploadInputsRegistered = true;
        }
        catch (Exception ex)
        {
            _error = $"[Images] Upload picker initialization failed: {ex.Message}";
            ToastService.Error(_error, "Upload failed");
        }
    }

    private void NavigateHome()
    {
        Navigation.NavigateTo("/");
    }

    private async Task RefreshImages()
    {
        _error = string.Empty;

        try
        {
            await Collection.Refresh();
            ApplyImages(Collection.Images);
        }
        catch (Exception ex)
        {
            _error = $"[Images] Refresh failed: {ex.Message}";
            ToastService.Error(_error, "Error");
        }
    }

    private void ApplyImages(IReadOnlyList<MediaImage> images)
    {
        _images = images.ToList();
        _totalPages = _images.Count == 0 ? 1 : (_images.Count + _pageSize - 1) / _pageSize;
        if (_page >= _totalPages)
            _page = Math.Max(0, _totalPages - 1);

        SyncSelectionWithImages();
        ApplyPage();
    }

    private void ApplyPage()
    {
        _pageImages = _images.Skip(_page * _pageSize).Take(_pageSize).ToList();
    }

    private void OnPageSizeChanged(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var size) || !PageSizes.Contains(size))
            return;

        _pageSize = size;
        _page = 0;
        ApplyImages(_images);
    }

    private void PrevPage()
    {
        if (_page <= 0) return;
        _page--;
        ApplyPage();
    }

    private void NextPage()
    {
        if (_page >= _totalPages - 1) return;
        _page++;
        ApplyPage();
    }

    private void OpenUpload()
    {
        ResetUploadProgress();
        _isUploadOpen = true;
        _uploadInputsRegistered = false;
    }

    private void CloseUpload()
    {
        if (_isUploading) return;
        _isUploadOpen = false;
        _uploadInputsRegistered = false;
    }

    private void OpenPreview(MediaImage image)
    {
        if (_isSelectionMode)
        {
            ToggleImageSelected(image);
            return;
        }

        _selectedImage = image;
    }

    private void ClosePreview()
    {
        _selectedImage = null;
    }

    private async Task PasteImageUrl()
    {
        _error = string.Empty;
        _isPasting = true;

        try
        {
            var clipboardText = await JS.InvokeAsync<string>("readClipboardText");
            if (!TryGetPastedImageUrl(clipboardText, out var uri, out var fileName, out var error))
            {
                ToastService.Error(error, "Paste failed");
                return;
            }

            var client = HttpClientFactory.CreateClient();
            using var request = new HttpRequestMessage(HttpMethod.Get, uri);
            using var response = await client.SendAsync(request, HttpCompletionOption.ResponseHeadersRead);

            if (!response.IsSuccessStatusCode)
            {
                ToastService.Error($"Download failed: HTTP {(int)response.StatusCode}", "Paste failed");
                return;
            }

            if (response.Content.Headers.ContentLength > MaxUploadFileSize)
            {
                ToastService.Error($"Image is too large: {FormatBytes(response.Content.Headers.ContentLength.Value)}", "Paste failed");
                return;
            }

            var contentType = response.Content.Headers.ContentType?.MediaType ?? string.Empty;
            if (!string.IsNullOrEmpty(contentType) &&
                !contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase) &&
                !contentType.Equals("application/octet-stream", StringComparison.OrdinalIgnoreCase))
            {
                ToastService.Error($"URL did not return an image. Content-Type: {contentType}", "Paste failed");
                return;
            }

            await using var stream = await response.Content.ReadAsStreamAsync();
            await Storage.SaveImage(fileName, stream);
            await Collection.Refresh();
            ApplyImages(Collection.Images);

            ToastService.Success($"Saved image from clipboard: {fileName}", "Done");
        }
        catch (JSException ex)
        {
            ToastService.Error($"Cannot read clipboard: {ex.Message}", "Paste failed");
        }
        catch (Exception ex)
        {
            ToastService.Error($"Could not parse or download image URL: {ex.Message}", "Paste failed");
        }
        finally
        {
            _isPasting = false;
        }
    }

    [JSInvokable]
    public Task OnHttpUploadStarted(int fileCount, long totalBytes)
    {
        _isUploading = true;
        _error = string.Empty;
        _uploadBytesDone = 0;
        _uploadBytesTotal = totalBytes;
        _uploadStatus = $"Preparing {fileCount} file(s)...";
        _uploadFileName = string.Empty;

        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnHttpUploadProgress(long bytesDone, long totalBytes, int fileIndex, int fileCount, string fileName)
    {
        if (!_isUploading && _uploadBytesTotal > 0)
            return Task.CompletedTask;

        _isUploading = true;
        _uploadBytesDone = Math.Clamp(bytesDone, 0, totalBytes);
        _uploadBytesTotal = totalBytes;
        _uploadStatus = $"Uploading {fileIndex} of {fileCount}";
        _uploadFileName = $"{fileIndex} / {fileCount}: {fileName}";

        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnHttpUploadCompleted(int uploaded, int failed, string errorMessage)
    {
        _isUploading = false;
        _uploadBytesDone = _uploadBytesTotal;
        _uploadStatus = $"Uploaded {uploaded} image(s)" + (failed > 0 ? $", failed {failed}" : "");
        _uploadFileName = failed > 0 ? "Finished with errors" : "Finished";

        if (!string.IsNullOrWhiteSpace(errorMessage))
            _error = $"[Images] {errorMessage}";

        try
        {
            await Collection.Refresh();
            ApplyImages(Collection.Images);
        }
        catch (Exception ex)
        {
            _error = $"[Images] Upload refresh failed: {ex.Message}";
            ToastService.Error(_error, "Error");
            StateHasChanged();
            return;
        }

        if (uploaded > 0 && failed == 0)
            ToastService.Success($"Uploaded {uploaded} image(s)", "Done");
        else if (uploaded > 0)
            ToastService.Warning($"Uploaded {uploaded} image(s), failed {failed}", "Upload finished");
        else
            ToastService.Error(string.IsNullOrWhiteSpace(errorMessage) ? "No images were uploaded." : errorMessage, "Upload failed");

        StateHasChanged();
    }

    [JSInvokable]
    public Task OnHttpUploadFailed(string errorMessage)
    {
        _isUploading = false;
        _error = $"[Images] Upload failed: {errorMessage}";
        _uploadStatus = "Upload failed";
        _uploadFileName = string.Empty;
        ToastService.Error(_error, "Upload failed");

        return InvokeAsync(StateHasChanged);
    }

    private void ResetUploadProgress()
    {
        _uploadStatus = string.Empty;
        _uploadFileName = string.Empty;
        _uploadBytesDone = 0;
        _uploadBytesTotal = 0;
    }

    private static bool TryGetPastedImageUrl(string? clipboardText, out Uri uri, out string fileName, out string error)
    {
        uri = null!;
        fileName = string.Empty;
        error = string.Empty;

        var candidate = ExtractFirstUrl(clipboardText);
        if (string.IsNullOrWhiteSpace(candidate))
        {
            error = "Clipboard does not contain a URL.";
            return false;
        }

        if (!Uri.TryCreate(candidate, UriKind.Absolute, out var parsed) ||
            (parsed.Scheme != Uri.UriSchemeHttps && parsed.Scheme != Uri.UriSchemeHttp))
        {
            error = "Clipboard URL must be an absolute http(s) link.";
            return false;
        }

        var extension = Path.GetExtension(parsed.AbsolutePath);
        if (!IsPastedImageExtension(extension))
        {
            error = "Clipboard URL must point to a .jpg, .jpeg, or .png image.";
            return false;
        }

        var parsedFileName = Path.GetFileName(Uri.UnescapeDataString(parsed.AbsolutePath));
        if (string.IsNullOrWhiteSpace(parsedFileName))
        {
            error = "Image URL does not contain a file name.";
            return false;
        }

        uri = parsed;
        fileName = parsedFileName;
        return true;
    }

    private static string ExtractFirstUrl(string? clipboardText)
    {
        var text = clipboardText?.Trim() ?? string.Empty;
        if (string.IsNullOrEmpty(text))
            return string.Empty;

        var trimmed = text.Trim('"', '\'', '<', '>', '(', ')', '[', ']');
        if (Uri.TryCreate(trimmed, UriKind.Absolute, out _))
            return trimmed;

        var match = System.Text.RegularExpressions.Regex.Match(text, @"https?://\S+", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        return match.Success
            ? match.Value.TrimEnd('.', ',', ';', ':', ')', ']', '}', '"', '\'')
            : string.Empty;
    }

    private static bool IsPastedImageExtension(string extension)
    {
        return extension.Equals(".jpg", StringComparison.OrdinalIgnoreCase) ||
               extension.Equals(".jpeg", StringComparison.OrdinalIgnoreCase) ||
               extension.Equals(".png", StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatBytes(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB"];
        var value = (double)bytes;
        var unit = 0;

        while (value >= 1024 && unit < units.Length - 1)
        {
            value /= 1024;
            unit++;
        }

        return unit == 0 ? $"{bytes} {units[unit]}" : $"{value:0.#} {units[unit]}";
    }

    private async Task DownloadAll()
    {
        if (_images.Count == 0)
            return;

        await JS.InvokeVoidAsync("downloadFileFromUrl", "/console/media/images/all.zip");
    }

    private void EnterSelectionMode()
    {
        _selectedImageKeys.Clear();
        _selectedImage = null;
        _isSelectionMode = true;
    }

    private void ExitSelectionMode()
    {
        _selectedImageKeys.Clear();
        _isSelectionMode = false;
    }

    private void ToggleImageSelected(MediaImage image)
    {
        if (!_selectedImageKeys.Add(image.Key))
            _selectedImageKeys.Remove(image.Key);
    }

    private async Task DownloadSelection()
    {
        var images = GetSelectedImages();
        if (images.Count == 0)
            return;

        if (images.Count == 1)
        {
            await JS.InvokeVoidAsync("downloadFileFromUrl", GetImageDownloadUrl(images[0]));
            return;
        }

        var query = string.Join("&", images.Select(image => $"key={Uri.EscapeDataString(image.Key)}"));
        await JS.InvokeVoidAsync("downloadFileFromUrl", $"/console/media/images/selected.zip?{query}");
    }

    private async Task DeleteSelection()
    {
        var images = GetSelectedImages();
        if (images.Count == 0)
            return;

        var message = images.Count == 1
            ? $"Delete image '{images[0].FileName}'?"
            : $"Delete {images.Count} selected images?";
        var confirmed = await JS.InvokeAsync<bool>("confirm", message);
        if (!confirmed)
            return;

        var removed = 0;
        var missing = 0;

        try
        {
            foreach (var image in images)
            {
                if (await Collection.Delete(image.Key))
                    removed++;
                else
                    missing++;
            }

            await Collection.Refresh();
            ApplyImages(Collection.Images);
            _selectedImageKeys.Clear();
            _isSelectionMode = false;

            if (removed > 0 && missing == 0)
                ToastService.Success($"Deleted {removed} image(s)", "Done");
            else if (removed > 0)
                ToastService.Warning($"Deleted {removed} image(s), {missing} already missing", "Done");
            else
                ToastService.Error("Selected images were not found", "Error");
        }
        catch (Exception ex)
        {
            _error = $"[Images] Delete failed: {ex.Message}";
            ToastService.Error(_error, "Error");
            await Collection.Refresh();
            ApplyImages(Collection.Images);
        }
    }

    private async Task DownloadSelected()
    {
        if (_selectedImage == null)
            return;

        await JS.InvokeVoidAsync("downloadFileFromUrl", GetImageDownloadUrl(_selectedImage));
    }

    private async Task DeleteSelected()
    {
        if (_selectedImage == null)
            return;

        var image = _selectedImage;
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Delete image '{image.FileName}'?");
        if (!confirmed)
            return;

        try
        {
            var removed = await Collection.Delete(image.Key);
            if (!removed)
            {
                ToastService.Error($"Image '{image.FileName}' was not found", "Error");
                return;
            }

            _selectedImage = null;
            ApplyImages(Collection.Images);
            ToastService.Success($"Deleted {image.FileName}", "Done");
        }
        catch (Exception ex)
        {
            _error = $"[Images] Delete failed: {ex.Message}";
            ToastService.Error(_error, "Error");
        }
    }

    private static string GetImageUrl(MediaImage image)
    {
        return $"/console/media/images/{Uri.EscapeDataString(image.Key)}";
    }

    private static string GetImageDownloadUrl(MediaImage image)
    {
        return $"/console/media/images/{Uri.EscapeDataString(image.Key)}/download";
    }

    private List<MediaImage> GetSelectedImages()
    {
        return _images.Where(image => _selectedImageKeys.Contains(image.Key)).ToList();
    }

    private void SyncSelectionWithImages()
    {
        if (_selectedImageKeys.Count == 0)
            return;

        var availableKeys = _images.Select(image => image.Key).ToHashSet(StringComparer.Ordinal);
        _selectedImageKeys.RemoveWhere(key => !availableKeys.Contains(key));
    }

    public void Dispose()
    {
        _uploadCallback?.Dispose();
    }
}
