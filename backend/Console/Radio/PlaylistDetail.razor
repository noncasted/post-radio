@page "/playlists/{PlaylistId:guid}"
@using global::Common.Extensions
@using global::Common.Reactive
@using global::Meta.Audio
@implements IDisposable

<PageTitle>@_name</PageTitle>
<PageHeader Title="@_name" />

<div class="container mx-auto max-w-5xl px-4 py-4 flex flex-col gap-4">
    <div class="rounded-lg border bg-card p-4 flex flex-col gap-3">
        <div class="flex flex-col gap-1">
            <div class="text-xs text-muted-foreground uppercase tracking-wide">Source</div>
            <div class="text-sm font-mono break-all">@_url</div>
            <div class="text-xs text-muted-foreground">
                @_songs.Count song(s), @_loadedCount loaded, @(_songs.Count - _loadedCount) pending
            </div>
        </div>

        <div class="flex items-center gap-3 flex-wrap">
            <BbButton Disabled="@_busy" @onclick="RunFetch">
                @if (_busy && _currentOp == "fetch")
                {
                    <LucideIcon Name="loader" Size="16" class="mr-2 animate-spin" />
                    <span>Fetching...</span>
                }
                else
                {
                    <LucideIcon Name="list-plus" Size="16" class="mr-2" />
                    <span>Fetch songs</span>
                }
            </BbButton>
            <BbButton Disabled="@_busy" @onclick="RunLoad">
                @if (_busy && _currentOp == "load")
                {
                    <LucideIcon Name="loader" Size="16" class="mr-2 animate-spin" />
                    <span>Loading...</span>
                }
                else
                {
                    <LucideIcon Name="cloud-download" Size="16" class="mr-2" />
                    <span>Load audio</span>
                }
            </BbButton>
            <span class="text-xs text-muted-foreground">@_status</span>
            <div class="flex-1"></div>
            <span class="text-xs text-muted-foreground">Sort: @CurrentSortDescription</span>
            <BbButton Variant="@(_sortBy == SortBy.Name ? ButtonVariant.Default : ButtonVariant.Outline)" Size="ButtonSize.Small" @onclick="@(() => SetSort(SortBy.Name))">
                Name
                @if (_sortBy == SortBy.Name)
                {
                    <LucideIcon Name="@SortDirectionIcon" Size="12" class="ml-1" />
                }
            </BbButton>
            <BbButton Variant="@(_sortBy == SortBy.AddDate ? ButtonVariant.Default : ButtonVariant.Outline)" Size="ButtonSize.Small" @onclick="@(() => SetSort(SortBy.AddDate))">
                Date
                @if (_sortBy == SortBy.AddDate)
                {
                    <LucideIcon Name="@SortDirectionIcon" Size="12" class="ml-1" />
                }
            </BbButton>
            <BbButton Variant="@(_sortBy == SortBy.Duration ? ButtonVariant.Default : ButtonVariant.Outline)" Size="ButtonSize.Small" @onclick="@(() => SetSort(SortBy.Duration))">
                Duration
                @if (_sortBy == SortBy.Duration)
                {
                    <LucideIcon Name="@SortDirectionIcon" Size="12" class="ml-1" />
                }
            </BbButton>
        </div>

        @if (!string.IsNullOrEmpty(_log))
        {
            <pre class="rounded bg-muted p-3 text-xs font-mono max-h-64 overflow-auto whitespace-pre-wrap">@_log</pre>
        }
    </div>

    <SongsList Source="@_songs" ShowUrl="false" EmptyText="No songs loaded for this playlist yet" />
</div>

@code {
    [Parameter] public Guid PlaylistId { get; set; }

    [Inject] public required IPlaylistsCollection Playlists { get; init; }
    [Inject] public required ISongsCollection Songs { get; init; }
    [Inject] public required IPlaylistLoader Loader { get; init; }

    private readonly ILifetime _lifetime = new Lifetime();

    private string _name = "Playlist";
    private string _url = string.Empty;
    private List<KeyValuePair<long, SongState>> _songs = new();
    private SortBy _sortBy = SortBy.AddDate;
    private bool _sortAscending;
    private int _loadedCount;

    private bool _busy;
    private string _currentOp = string.Empty;
    private string _status = string.Empty;
    private string _log = string.Empty;

    private enum SortBy { Name, AddDate, Duration }

    private string SortDirectionIcon => _sortAscending ? "arrow-up" : "arrow-down";

    private string CurrentSortDescription => _sortBy switch
    {
        SortBy.Name => _sortAscending ? "name A-Z" : "name Z-A",
        SortBy.AddDate => _sortAscending ? "oldest first" : "newest first",
        SortBy.Duration => _sortAscending ? "shortest first" : "longest first",
        _ => "default"
    };

    protected override void OnInitialized()
    {
        Reload();
        Playlists.Updated.Advise(_lifetime, () => InvokeAsync(() => { Reload(); StateHasChanged(); }));
        Songs.Updated.Advise(_lifetime, () => InvokeAsync(() => { Reload(); StateHasChanged(); }));
    }

    private void Reload()
    {
        if (Playlists.TryGetValue(PlaylistId, out var playlist))
        {
            _name = string.IsNullOrEmpty(playlist.Name) ? "Untitled" : playlist.Name;
            _url = playlist.Url;
        }

        var songs = SafeSnapshot(Songs, kv => kv.Value.Playlists.Contains(PlaylistId));
        _loadedCount = songs.Count(kv => kv.Value.IsLoaded);
        _songs = ApplySort(songs);
    }


    private List<KeyValuePair<long, SongState>> ApplySort(IEnumerable<KeyValuePair<long, SongState>> songs)
    {
        return (_sortBy switch
        {
            SortBy.Name => _sortAscending
                ? songs.OrderBy(kv => kv.Value.Name)
                : songs.OrderByDescending(kv => kv.Value.Name),
            SortBy.Duration => _sortAscending
                ? songs.OrderBy(kv => kv.Value.DurationMs ?? long.MaxValue)
                : songs.OrderByDescending(kv => kv.Value.DurationMs ?? -1),
            SortBy.AddDate => _sortAscending
                ? songs.OrderBy(kv => kv.Value.AddDate)
                : songs.OrderByDescending(kv => kv.Value.AddDate),
            _ => songs
        }).ToList();
    }

    private void SetSort(SortBy sort)
    {
        if (_sortBy == sort)
        {
            _sortAscending = !_sortAscending;
            Reload();
            return;
        }

        _sortBy = sort;
        _sortAscending = DefaultSortAscending(sort);
        Reload();
    }

    private static bool DefaultSortAscending(SortBy sort)
    {
        return sort == SortBy.Name;
    }

    private Task RunFetch() => RunOp("fetch", (data, progress) => Loader.Fetch(data, progress));
    private Task RunLoad() => RunOp("load", (data, progress) => Loader.Load(data, progress));

    private async Task RunOp(string op, Func<PlaylistData, IOperationProgress, Task> action)
    {
        if (!Playlists.TryGetValue(PlaylistId, out var playlist))
            return;

        _busy = true;
        _currentOp = op;
        _status = "Running";
        _log = string.Empty;
        StateHasChanged();

        var progress = new OperationProgress();
        progress.Message.Advise(_lifetime, (_, msg) => {
            _log += msg + "\n";
            InvokeAsync(StateHasChanged);
        });

        try
        {
            var data = new PlaylistData
            {
                Id = PlaylistId,
                Url = playlist.Url,
                Name = playlist.Name
            };

            await action(data, progress);
            _status = progress.Status.Value.ToString();
        }
        catch (Exception ex)
        {
            _status = "Failed: " + ex.Message;
        }
        finally
        {
            _busy = false;
            _currentOp = string.Empty;
            StateHasChanged();
        }
    }

    private static List<KeyValuePair<long, SongState>> SafeSnapshot(
        ISongsCollection source, Func<KeyValuePair<long, SongState>, bool> predicate)
    {
        for (var attempt = 0; attempt < 5; attempt++)
        {
            try { return source.Where(predicate).ToList(); }
            catch (InvalidOperationException) { }
        }
        return new List<KeyValuePair<long, SongState>>();
    }

    public void Dispose() => _lifetime.Terminate();
}
