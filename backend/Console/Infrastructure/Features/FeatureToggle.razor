@if (Value)
{
    <div class="flex items-center justify-between py-1">
        <div class="flex flex-col gap-0.5">
            <span class="text-sm font-medium">@Label</span>
            <span class="text-xs text-muted-foreground">@Description</span>
        </div>
        <BbButton Variant="ButtonVariant.Default" @onclick="OnToggle" Disabled="Saving">
            <LucideIcon Name="check" Size="14" class="mr-2"/>
            <span>Enabled</span>
        </BbButton>
    </div>
}
else
{
    <div class="flex items-center justify-between py-1">
        <div class="flex flex-col gap-0.5">
            <span class="text-sm font-medium">@Label</span>
            <span class="text-xs text-muted-foreground">@Description</span>
        </div>
        <BbButton Variant="ButtonVariant.Outline" @onclick="OnToggle" Disabled="Saving">
            <LucideIcon Name="x" Size="14" class="mr-2"/>
            <span>Disabled</span>
        </BbButton>
    </div>
}

@code {
    [Parameter] public required string Label { get; set; }
    [Parameter] public required string Description { get; set; }
    [Parameter] public bool Value { get; set; }
    [Parameter] public EventCallback OnToggle { get; set; }
    [Parameter] public bool Saving { get; set; }
}
