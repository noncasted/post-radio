@page "/benchmarks"

<PageTitle>Benchmarks</PageTitle>
<PageHeader Title="Benchmarks"/>

<div class="container mx-auto max-w-4xl px-4 py-4 flex flex-col gap-6">
    <div class="rounded-lg border bg-card p-6 flex flex-col gap-4">
        <div class="flex items-center gap-3">
            <div class="rounded-lg bg-primary/10 p-2.5">
                <LucideIcon Name="flask-conical" Size="20" class="text-primary" />
            </div>
            <div>
                <h2 class="text-lg font-semibold">Benchmark dashboard</h2>
                <p class="text-sm text-muted-foreground">This route is wired for the infrastructure dashboard.</p>
            </div>
        </div>

        <div class="text-sm text-muted-foreground leading-relaxed">
            Benchmark records are stored through the state system. Use the State Explorer for raw benchmark state until
            a dedicated benchmark runner/results UI is added here.
        </div>

        <a href="@ConsoleConstants.Pages.StateExplorer" class="inline-flex items-center gap-1 text-sm text-primary font-medium">
            Open State Explorer
            <LucideIcon Name="arrow-right" Size="14" />
        </a>
    </div>
</div>
