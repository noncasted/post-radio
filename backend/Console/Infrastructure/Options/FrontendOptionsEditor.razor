@using global::Cluster.Configs
<div class="rounded-lg border bg-card p-4 flex flex-col gap-3">
    <div class="flex items-center gap-2">
        <div class="rounded-md bg-sky-500/15 p-1.5">
            <LucideIcon Name="monitor" Size="14" class="text-sky-400" />
        </div>
        <h2 class="text-sm font-semibold">Frontend</h2>
    </div>
    <div class="flex flex-col">
        <div class="flex items-center gap-3 py-1.5 border-b border-border/60">
            <LucideIcon Name="volume-2" Size="12" class="text-muted-foreground shrink-0" />
            <span class="text-sm flex-1">Base Volume (0..1, relative between min and max)</span>
            <input type="number" step="0.01" min="0" max="1" @bind="Value.BaseVolume"
                   class="w-24 h-8 rounded-md border border-input bg-transparent px-2 text-sm shadow-sm" />
        </div>
        <div class="flex items-center gap-3 py-1.5 border-b border-border/60">
            <LucideIcon Name="volume-x" Size="12" class="text-muted-foreground shrink-0" />
            <span class="text-sm flex-1">Min Volume</span>
            <input type="number" step="0.01" min="0" max="1" @bind="Value.MinVolume"
                   class="w-24 h-8 rounded-md border border-input bg-transparent px-2 text-sm shadow-sm" />
        </div>
        <div class="flex items-center gap-3 py-1.5 border-b border-border/60">
            <LucideIcon Name="volume" Size="12" class="text-muted-foreground shrink-0" />
            <span class="text-sm flex-1">Max Volume</span>
            <input type="number" step="0.01" min="0" max="1" @bind="Value.MaxVolume"
                   class="w-24 h-8 rounded-md border border-input bg-transparent px-2 text-sm shadow-sm" />
        </div>
        <div class="flex items-center gap-3 py-1.5 border-b border-border/60">
            <LucideIcon Name="images" Size="12" class="text-muted-foreground shrink-0" />
            <span class="text-sm flex-1">Image Switch Interval (ms)</span>
            <input type="number" @bind="Value.ImageSwitchIntervalMs"
                   class="w-24 h-8 rounded-md border border-input bg-transparent px-2 text-sm shadow-sm" />
        </div>
        <div class="flex items-center gap-3 py-1.5">
            <LucideIcon Name="sunrise" Size="12" class="text-muted-foreground shrink-0" />
            <span class="text-sm flex-1">Image Fade Duration (ms)</span>
            <input type="number" @bind="Value.ImageFadeMs"
                   class="w-24 h-8 rounded-md border border-input bg-transparent px-2 text-sm shadow-sm" />
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public FrontendOptions Value { get; set; } = null!;
}
