@page "/"

<PageTitle>Console</PageTitle>

<div class="h-full px-6 py-8">
    <div class="flex gap-8 h-full">
        <div class="w-1/2 flex flex-col gap-3">
            <div class="flex items-center gap-2">
                <div class="rounded-md bg-pink-500/15 p-1.5">
                    <LucideIcon Name="radio" Size="14" class="text-pink-400" />
                </div>
                <h2 class="text-sm font-semibold">Radio</h2>
            </div>

            <OnlineTrackerWidget />

            <div class="grid grid-cols-2 gap-3">
                <HomeNavCard Icon="list-music" Title="Playlists" Description="Browse and create playlists" Target="@ConsoleConstants.Pages.Playlists" />
                <HomeNavCard Icon="music" Title="Songs" Description="All tracks across playlists" Target="@ConsoleConstants.Pages.Songs" />
                <HomeNavCard Icon="image" Title="Images" Description="Background imagery" Target="@ConsoleConstants.Pages.Images" />
                <HomeNavCard Icon="monitor" Title="Frontend Options" Description="Tune player volume and image timing" Target="@ConsoleConstants.Pages.FrontendOptions" />
            </div>
        </div>

        <div class="w-1/2 flex flex-col gap-6">
            <PlaylistsWidget />
            <SongsWidget />
        </div>
    </div>
</div>

