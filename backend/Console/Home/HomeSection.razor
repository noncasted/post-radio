<div class="flex flex-col gap-3">
    <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider">@Title</h2>
    <div class="grid grid-cols-3 gap-3">
        @ChildContent
    </div>
</div>

@code {
    [Parameter] public required string Title { get; init; }
    [Parameter] public required RenderFragment ChildContent { get; init; }
}
