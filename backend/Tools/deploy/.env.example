# sc-tunnel's AmneziaWG config comes from the mounted file secret
# `secrets/awg_config`, not env vars. Copy the AmneziaWG client .conf
# (exported from the AmneziaVPN desktop/mobile app, or from the provider)
# to backend/Tools/deploy/secrets/awg_config before `docker compose up`.
#
# No env vars are needed for sc-tunnel itself; this file is kept for any
# future additions to the compose topology.
