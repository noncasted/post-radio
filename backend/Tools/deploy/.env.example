# Copy to .env.local for local smoke tests, or set these in the Coolify UI for production deploys.

# === Database (external Postgres) ===
# Host is the Coolify-internal DNS name of a managed Postgres resource, or any reachable Postgres host.
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=postradio
DB_USER=postradio
DB_PASSWORD=change-me

# === Media storage ===
# Runtime media files live in the compose media-data volume mounted at /app/media.
# Override only if you also update the compose volume target.
# MediaStorage__RootPath=/app/media

# === Application tokens ===
# Console login token (required for /login?token= deep link).
CONSOLE_TOKEN=change-me

# === Aspire dashboard ===
ASPIRE_TOKEN=change-me
# Shared secret services use to push OTLP to the dashboard. Any random string.
OTEL_API_KEY=change-me-to-random-string

# === Coolify-specific (auto-injected by Coolify — do not set manually locally) ===
# SERVICE_FQDN_META_8080=https://api.yourdomain.com
# SERVICE_FQDN_CONSOLE_8080=https://console.yourdomain.com
# SERVICE_FQDN_FRONTEND_8080=https://yourdomain.com
# SERVICE_FQDN_ASPIREDASHBOARD_18888=https://aspire.yourdomain.com
