@using Frontend.Client.Services
@implements IDisposable

<div class="skip-notifications">
    @foreach (var item in _visible)
    {
        <div class="skip-toast @item.Notification.Severity" @key="item.Id" title="@BuildTooltip(item.Notification)">
            <span class="skip-toast-text">@FormatMessage(item.Notification.Reason)</span>
            <button class="skip-toast-close" @onclick="@(() => Dismiss(item))" title="Dismiss">x</button>
        </div>
    }
</div>

<style>
    .skip-notifications {
        position: fixed;
        left: 16px;
        bottom: 16px;
        display: flex;
        flex-direction: column-reverse;
        gap: 4px;
        z-index: 40;
        max-width: min(240px, calc(100vw - 32px));
        pointer-events: auto;
    }
    .skip-toast {
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(18, 18, 26, 0.94);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-left-width: 3px;
        border-radius: 4px;
        padding: 5px 7px;
        color: #f2f2f2;
        font-family: system-ui, -apple-system, sans-serif;
        font-size: 11px;
        line-height: 1.1;
        animation: skip-toast-in 0.18s ease;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.4);
    }
    .skip-toast.info { border-left-color: #5aa9e6; }
    .skip-toast.warning { border-left-color: #f5a623; }
    .skip-toast.error { border-left-color: #e05555; }
    .skip-toast-text {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .skip-toast-close {
        background: none;
        border: none;
        color: rgba(255, 255, 255, 0.45);
        cursor: pointer;
        font-size: 11px;
        padding: 0 2px;
        line-height: 1;
    }
    .skip-toast-close:hover { color: #fff; }
    @@keyframes skip-toast-in {
        from { opacity: 0; transform: translateX(-10px); }
        to { opacity: 1; transform: translateX(0); }
    }
</style>

@code {
    [Parameter] public required SessionState State { get; set; }

    private static readonly TimeSpan ToastLifetime = TimeSpan.FromSeconds(15);

    private readonly List<VisibleItem> _visible = new();
    private Action<SkipNotification>? _handler;

    protected override void OnInitialized()
    {
        _handler = OnSkipReported;
        State.SkipReported += _handler;
    }

    private void OnSkipReported(SkipNotification notification)
    {
        _ = InvokeAsync(async () =>
        {
            var item = new VisibleItem(Guid.NewGuid(), notification);
            _visible.Add(item);
            while (_visible.Count > 5)
                _visible.RemoveAt(0);

            StateHasChanged();

            try
            {
                await Task.Delay(ToastLifetime, State.Token);
            }
            catch (OperationCanceledException)
            {
                return;
            }

            _visible.Remove(item);
            StateHasChanged();
        });
    }

    private void Dismiss(VisibleItem item)
    {
        _visible.Remove(item);
        StateHasChanged();
    }

    public void Dispose()
    {
        if (_handler != null)
            State.SkipReported -= _handler;
    }

    private static string FormatMessage(string reason)
    {
        return string.IsNullOrWhiteSpace(reason)
            ? "Skipped"
            : $"Skipped ({reason})";
    }

    private static string BuildTooltip(SkipNotification notification)
    {
        return string.IsNullOrWhiteSpace(notification.Title)
            ? FormatMessage(notification.Reason)
            : $"{FormatMessage(notification.Reason)} — {notification.Title}";
    }

    private sealed record VisibleItem(Guid Id, SkipNotification Notification);
}
