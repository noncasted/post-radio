@using Frontend.Client.Services
@implements IDisposable

<div class="skip-notifications">
    @foreach (var item in _visible)
    {
        <div class="skip-toast @item.Notification.Severity" @key="item.Id">
            <div class="skip-toast-head">
                <span class="skip-toast-title">@item.Notification.Title</span>
                <button class="skip-toast-close" @onclick="@(() => Dismiss(item))" title="Dismiss">x</button>
            </div>
            @if (!string.IsNullOrWhiteSpace(item.Notification.SongLabel))
            {
                <div class="skip-toast-song">@item.Notification.SongLabel</div>
            }
            <div class="skip-toast-reason">reason=@item.Notification.Reason @item.Notification.TimestampUtc.ToLocalTime().ToString("HH:mm:ss")</div>
            @if (item.Notification.Details.Count > 0)
            {
                <details class="skip-toast-details" open="@item.ExpandedByDefault">
                    <summary>state</summary>
                    <ul>
                        @foreach (var kv in item.Notification.Details)
                        {
                            <li><span class="k">@kv.Key:</span> <span class="v">@(kv.Value ?? "-")</span></li>
                        }
                    </ul>
                </details>
            }
        </div>
    }
</div>

<style>
    .skip-notifications {
        position: fixed;
        left: 16px;
        bottom: 16px;
        display: flex;
        flex-direction: column-reverse;
        gap: 8px;
        z-index: 40;
        max-width: 380px;
        pointer-events: auto;
    }
    .skip-toast {
        background: rgba(18, 18, 26, 0.94);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-left-width: 3px;
        border-radius: 4px;
        padding: 8px 10px;
        color: #f2f2f2;
        font-family: system-ui, -apple-system, sans-serif;
        font-size: 12px;
        line-height: 1.4;
        animation: skip-toast-in 0.18s ease;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.4);
    }
    .skip-toast.info { border-left-color: #5aa9e6; }
    .skip-toast.warning { border-left-color: #f5a623; }
    .skip-toast.error { border-left-color: #e05555; }
    .skip-toast-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 8px;
    }
    .skip-toast-title { font-weight: 600; }
    .skip-toast-close {
        background: none;
        border: none;
        color: rgba(255, 255, 255, 0.45);
        cursor: pointer;
        font-size: 12px;
        padding: 0 2px;
        line-height: 1;
    }
    .skip-toast-close:hover { color: #fff; }
    .skip-toast-song { opacity: 0.9; margin-top: 1px; }
    .skip-toast-reason {
        opacity: 0.55;
        margin-top: 3px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 10.5px;
    }
    .skip-toast-details { margin-top: 6px; opacity: 0.85; }
    .skip-toast-details summary {
        cursor: pointer;
        font-size: 10.5px;
        opacity: 0.75;
        user-select: none;
    }
    .skip-toast-details ul {
        margin: 4px 0 0 0;
        padding-left: 0;
        list-style: none;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 10.5px;
    }
    .skip-toast-details li { margin: 1px 0; }
    .skip-toast-details .k { opacity: 0.6; }
    .skip-toast-details .v { opacity: 0.95; }
    @@keyframes skip-toast-in {
        from { opacity: 0; transform: translateX(-10px); }
        to { opacity: 1; transform: translateX(0); }
    }
</style>

@code {
    [Parameter] public required SessionState State { get; set; }

    private static readonly TimeSpan ToastLifetime = TimeSpan.FromSeconds(15);

    private readonly List<VisibleItem> _visible = new();
    private Action<SkipNotification>? _handler;

    protected override void OnInitialized()
    {
        _handler = OnSkipReported;
        State.SkipReported += _handler;
    }

    private void OnSkipReported(SkipNotification notification)
    {
        _ = InvokeAsync(async () =>
        {
            var item = new VisibleItem(Guid.NewGuid(), notification, notification.Severity != "info");
            _visible.Add(item);
            while (_visible.Count > 5)
                _visible.RemoveAt(0);

            StateHasChanged();

            try
            {
                await Task.Delay(ToastLifetime, State.Token);
            }
            catch (OperationCanceledException)
            {
                return;
            }

            _visible.Remove(item);
            StateHasChanged();
        });
    }

    private void Dismiss(VisibleItem item)
    {
        _visible.Remove(item);
        StateHasChanged();
    }

    public void Dispose()
    {
        if (_handler != null)
            State.SkipReported -= _handler;
    }

    private sealed record VisibleItem(Guid Id, SkipNotification Notification, bool ExpandedByDefault);
}
