@using Frontend.Client.Services
@inject IRadioApi Api
@implements IDisposable

<div class="image-container">
    <img style="position: fixed; left: 0; z-index: -1" src="@_first.Url" class="@($"{_first.State} blurry sub")" />
    <img style="position: fixed; left: 50%; z-index: -1" src="@_first.Url" class="@($"{_first.State} blurry sub")" />
    <img style="z-index: 1" src="@_first.Url" class="@($"{_first.State} main")" />
    <img style="position: fixed; left: 0; z-index: -1" src="@_second.Url" class="@($"{_second.State} blurry sub")" />
    <img style="position: fixed; left: 50%; z-index: -1" src="@_second.Url" class="@($"{_second.State} blurry sub")" />
    <img style="z-index: 1" src="@_second.Url" class="@($"{_second.State} main")" />
</div>

<style>
    .image-container {
        position: fixed;
        top: 0; left: 0;
        width: 100vw; height: 100vh;
        overflow: hidden;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #0a0a14;
    }
    .image {
        position: absolute;
        object-fit: cover;
        object-position: center;
        transition: opacity @(_fadeSeconds.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture))s ease-in-out;
    }
    .sub { height: 100%; width: 50%; }
    .main { height: 115%; }
    .hidden { opacity: 0; }
    .visible { opacity: 1; }
    .blurry { filter: blur(18px); }
</style>

@code {
    [Parameter] public required SessionState State { get; set; }

    private readonly ImageHandle _first = new();
    private readonly ImageHandle _second = new();
    private int _totalImages;
    private double _fadeSeconds = 1.0;
    private bool _disposed;
    private CancellationTokenSource? _componentCts;
    private Task? _cycleTask;

    protected override async Task OnInitializedAsync()
    {
        _fadeSeconds = State.Options.ImageFadeMs / 1000.0;
        _componentCts = CancellationTokenSource.CreateLinkedTokenSource(State.Token);
        State.OptionsChanged += OnOptionsChanged;

        var token = _componentCts.Token;
        _totalImages = await Api.GetImagesCount();

        if (_disposed || token.IsCancellationRequested)
            return;

        EnsureCycleStarted(token);
    }

    private void OnOptionsChanged()
    {
        if (_disposed)
            return;

        _fadeSeconds = State.Options.ImageFadeMs / 1000.0;
        _ = InvokeAsync(StateHasChanged);
    }

    private void EnsureCycleStarted(CancellationToken token)
    {
        if (_cycleTask is { IsCompleted: false })
            return;

        _cycleTask = Cycle(token);
    }

    private async Task Cycle(CancellationToken token)
    {
        var current = _first;

        while (!token.IsCancellationRequested)
        {
            try
            {
                if (_totalImages == 0)
                {
                    await Task.Delay(TimeSpan.FromSeconds(5), token);
                    _totalImages = await Api.GetImagesCount();

                    if (_disposed || token.IsCancellationRequested)
                        return;

                    continue;
                }

                current.Hide();
                current = current == _first ? _second : _first;
                var index = State.IncImageIndex(_totalImages);
                var url = await Api.GetImageUrl(index);

                if (_disposed || token.IsCancellationRequested)
                    return;

                current.Url = url;
                current.Show();

                await InvokeAsync(StateHasChanged);
                await Task.Delay(TimeSpan.FromMilliseconds(State.Options.ImageSwitchIntervalMs), token);
            }
            catch (OperationCanceledException)
            {
                return;
            }
            catch (Exception)
            {
                try { await Task.Delay(TimeSpan.FromSeconds(1), token); }
                catch (OperationCanceledException) { return; }
            }
        }
    }

    public void Dispose()
    {
        if (_disposed)
            return;

        _disposed = true;
        State.OptionsChanged -= OnOptionsChanged;
        _componentCts?.Cancel();
        _componentCts?.Dispose();
    }

    public class ImageHandle
    {
        public string State { get; private set; } = "image fade-in hidden";
        public string Url { get; set; } = string.Empty;
        public void Show() => State = "image fade-in visible";
        public void Hide() => State = "image fade-in hidden";
    }
}
