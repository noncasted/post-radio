@inherits LayoutComponentBase

<div class="relative min-h-screen flex flex-col">
    <header class="sticky top-0 z-50 w-full border-b bg-background">
        <div class="container flex h-14 items-center">
            <div class="mr-4 flex">
                <a href="/" class="mr-6 flex items-center space-x-2">
                    <LucideIcon Name="box" Size="24" class="text-primary" />
                    <span class="font-bold">Console</span>
                </a>
            </div>
            <nav class="flex items-center space-x-6 text-sm font-medium">
                <NavLink href="/" Match="NavLinkMatch.All" class="transition-colors hover:text-foreground/80 text-foreground/60" ActiveClass="text-foreground">
                    Main
                </NavLink>
                <NavLink href="/infrastructure" class="transition-colors hover:text-foreground/80 text-foreground/60" ActiveClass="text-foreground">
                    Infrastructure
                </NavLink>
            </nav>
            <div class="flex flex-1 items-center justify-end space-x-4">
                <StartupStatusIndicator OnClick="ShowStartupOverlay" />
                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" @onclick="ToggleDarkMode">
                    @if (isDarkMode)
                    {
                        <LucideIcon Name="sun" Size="20" />
                    }
                    else
                    {
                        <LucideIcon Name="moon" Size="20" />
                    }
                </BbButton>
            </div>
        </div>
    </header>

    <main class="flex-1">
        @Body
    </main>
</div>

<StartupOverlay @ref="_startupOverlay" />
<BbToastProvider Position="ToastPosition.BottomRight" />
<BbDialogProvider />
<BbPortalHost />
