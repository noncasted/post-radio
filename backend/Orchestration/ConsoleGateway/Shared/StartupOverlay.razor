@using Common.Extensions
@using Common.Reactive
@using Infrastructure.Startup
@using UiComponent = Console.UiComponent
@inherits UiComponent

@if (_showOverlay) {
    <div class="fixed inset-0 z-[100] flex items-center justify-center" style="background: rgba(0, 0, 0, 0.3); backdrop-filter: blur(8px);">
        <div class="border bg-card shadow-2xl" style="width: 540px; border-radius: 16px; padding: 40px;">
            <div class="flex items-center justify-between" style="margin-bottom: 28px;">
                <div class="flex items-center gap-3">
                    @if (_isInitialized) {
                        <LucideIcon Name="circle-check" Size="28" class="text-green-500"/>
                        <h2 class="text-xl font-semibold">Server ready</h2>
                    }
                    else {
                        <LucideIcon Name="loader-circle" Size="28" class="animate-spin text-primary"/>
                        <h2 class="text-xl font-semibold">Server is starting up</h2>
                    }
                </div>
                <button class="rounded-lg p-1.5 hover:bg-muted transition-colors" @onclick="Close">
                    <LucideIcon Name="x" Size="20" class="text-muted-foreground"/>
                </button>
            </div>

            <div class="flex flex-col gap-1">
                @for (var i = 0; i < _stages.Count; i++) {
                    var stage = _stages[i];

                    @if (i < _currentStageIndex) {
                        <div class="flex items-center gap-3 py-2">
                            <LucideIcon Name="circle-check" Size="20" class="text-green-500 shrink-0"/>
                            <span class="text-[15px] text-muted-foreground">@stage</span>
                        </div>
                    }
                    else if (i == _currentStageIndex) {
                        <div class="flex items-center gap-3 py-2">
                            <LucideIcon Name="loader-circle" Size="20" class="animate-spin text-primary shrink-0"/>
                            <span class="text-[15px] font-medium">@stage</span>
                        </div>
                    }
                    else {
                        <div class="flex items-center gap-3 py-2">
                            <LucideIcon Name="circle" Size="20" class="text-muted-foreground/30 shrink-0"/>
                            <span class="text-[15px] text-muted-foreground/40">@stage</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    [Inject] public IClusterParticipantContext ClusterParticipantContext { get; set; } = null!;

    private bool _isInitialized;
    private bool _showOverlay;
    private IReadOnlyList<string> _stages = Array.Empty<string>();
    private int _currentStageIndex;

    protected override Task OnSetup(IReadOnlyLifetime lifetime) {
        _showOverlay = !ClusterParticipantContext.IsInitialized.Value;

        ClusterParticipantContext.IsInitialized.View(lifetime, value => {
            _isInitialized = value;
            InvokeAsync(StateHasChanged).NoAwait();
        });

        ClusterParticipantContext.CurrentStageIndex.View(lifetime, index => {
            _currentStageIndex = index;
            _stages = ClusterParticipantContext.Stages;
            InvokeAsync(StateHasChanged).NoAwait();
        });

        return Task.CompletedTask;
    }

    public void Show() {
        _showOverlay = true;
        InvokeAsync(StateHasChanged).NoAwait();
    }

    private void Close() {
        _showOverlay = false;
    }
}
