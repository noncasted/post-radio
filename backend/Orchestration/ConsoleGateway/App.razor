@using static Microsoft.AspNetCore.Components.Web.RenderMode

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>
    <!-- Theme CSS variables - must load first -->
    <link href="styles/themes/ocean.css" rel="stylesheet"/>
    <!-- BlazorBlueprint component styles -->
    <link href="_content/BlazorBlueprint.Components/blazorblueprint.css" rel="stylesheet"/>
    <!-- App styles (Tailwind utilities for template pages) -->
    <link href="css/app.css" rel="stylesheet"/>
    <HeadOutlet/>
</head>
<body class="font-sans antialiased">
<Routes @rendermode="InteractiveServer"/>

<div id="blazor-error-ui" class="hidden fixed bottom-0 left-0 right-0 z-50 p-4 bg-destructive text-destructive-foreground">
    An error has occurred. This application may no longer respond until reloaded.
    <a href="" class="underline">Reload</a>
</div>

<!-- Preload Floating UI for positioning (Select, Popover, etc.) -->
<script type="module">
        import * as FloatingUI from 'https://cdn.jsdelivr.net/npm/@@floating-ui/dom@@1.5.3/+esm';
        window.FloatingUIDOM = FloatingUI;
    </script>

<script src="_framework/blazor.web.js"></script>
<script>
        window.toggleDarkMode = () => document.documentElement.classList.toggle('dark');
        window.isDarkModeEnabled = () => document.documentElement.classList.contains('dark');
        window.downloadFileFromBase64 = (fileName, base64, mimeType) => {
            const link = document.createElement('a');
            link.href = 'data:' + mimeType + ';base64,' + base64;
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };
    </script>
</body>
</html>