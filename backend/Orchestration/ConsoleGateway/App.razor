@using static Microsoft.AspNetCore.Components.Web.RenderMode

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>
    <!-- Theme CSS variables - must load first -->
    <link href="styles/themes/ocean.css" rel="stylesheet"/>
    <!-- BlazorBlueprint component styles -->
    <link href="_content/BlazorBlueprint.Components/blazorblueprint.css" rel="stylesheet"/>
    <!-- App styles (Tailwind utilities for template pages) -->
    <link href="css/app.css" rel="stylesheet"/>
    <HeadOutlet/>
</head>
<body class="font-sans antialiased">
<Routes @rendermode="InteractiveServer"/>

<div id="blazor-error-ui" class="hidden fixed bottom-0 left-0 right-0 z-50 p-4 bg-destructive text-destructive-foreground">
    An error has occurred. This application may no longer respond until reloaded.
    <a href="" class="underline">Reload</a>
</div>

<!-- Preload Floating UI for positioning (Select, Popover, etc.) -->
<script type="module">
        import * as FloatingUI from 'https://cdn.jsdelivr.net/npm/@@floating-ui/dom@@1.5.3/+esm';
        window.FloatingUIDOM = FloatingUI;
    </script>

<script src="_framework/blazor.web.js"></script>
<script>
        window.toggleDarkMode = () => document.documentElement.classList.toggle('dark');
        window.isDarkModeEnabled = () => document.documentElement.classList.contains('dark');
        window.downloadFileFromBase64 = (fileName, base64, mimeType) => {
            const link = document.createElement('a');
            link.href = 'data:' + mimeType + ';base64,' + base64;
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };
        window.downloadFileFromUrl = (url) => {
            const link = document.createElement('a');
            link.href = url;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };
        window.readClipboardText = async () => await navigator.clipboard.readText();
        window.registerImageUploadInput = (inputId, endpoint, dotNetHelper, maxFileSize, maxFileCount) => {
            const input = document.getElementById(inputId);
            if (!input) {
                throw new Error(`Upload input '${inputId}' was not found.`);
            }

            if (input.dataset.imageUploadRegistered === '1') {
                return;
            }

            input.dataset.imageUploadRegistered = '1';
            input.addEventListener('change', async () => {
                const files = Array.from(input.files || []);
                input.value = '';
                await window.uploadImageFiles(files, endpoint, dotNetHelper, maxFileSize, maxFileCount);
            });
        };
        window.uploadImageFiles = async (files, endpoint, dotNetHelper, maxFileSize, maxFileCount) => {
            try {
                const candidates = files.filter(isImageUploadCandidate);
                if (candidates.length === 0) {
                    await dotNetHelper.invokeMethodAsync('OnHttpUploadFailed', 'No image files were selected.');
                    return;
                }

                if (candidates.length > maxFileCount) {
                    await dotNetHelper.invokeMethodAsync('OnHttpUploadFailed', `Too many files selected: ${candidates.length}. Limit is ${maxFileCount}.`);
                    return;
                }

                const totalBytes = candidates.reduce((sum, file) => sum + file.size, 0);
                await dotNetHelper.invokeMethodAsync('OnHttpUploadStarted', candidates.length, totalBytes);

                let uploaded = 0;
                let failed = 0;
                let completedBytes = 0;
                let firstError = '';

                for (let index = 0; index < candidates.length; index++) {
                    const file = candidates[index];

                    if (file.size > maxFileSize) {
                        failed++;
                        completedBytes += file.size;
                        firstError ||= `${file.name} is too large.`;
                        await dotNetHelper.invokeMethodAsync('OnHttpUploadProgress', completedBytes, totalBytes, index + 1, candidates.length, file.name);
                        continue;
                    }

                    try {
                        await uploadOneImage(file, endpoint, (loaded) => {
                            reportUploadProgress(dotNetHelper, completedBytes + loaded, totalBytes, index + 1, candidates.length, file.name);
                        });
                        uploaded++;
                    } catch (error) {
                        failed++;
                        firstError ||= `${file.name}: ${error.message || error}`;
                    } finally {
                        completedBytes += file.size;
                        await dotNetHelper.invokeMethodAsync('OnHttpUploadProgress', completedBytes, totalBytes, index + 1, candidates.length, file.name);
                    }
                }

                await dotNetHelper.invokeMethodAsync('OnHttpUploadCompleted', uploaded, failed, firstError);
            } catch (error) {
                await dotNetHelper.invokeMethodAsync('OnHttpUploadFailed', error.message || String(error));
            }
        };

        const reportUploadProgress = (() => {
            let lastReportAt = 0;
            return (dotNetHelper, bytesDone, totalBytes, fileIndex, fileCount, fileName) => {
                const now = performance.now();
                if (now - lastReportAt < 120 && bytesDone < totalBytes) {
                    return;
                }

                lastReportAt = now;
                dotNetHelper.invokeMethodAsync('OnHttpUploadProgress', Math.round(bytesDone), Math.round(totalBytes), fileIndex, fileCount, fileName);
            };
        })();

        const isImageUploadCandidate = (file) => {
            if (file.type && file.type.toLowerCase().startsWith('image/')) {
                return true;
            }

            return /\.(avif|bmp|gif|heic|jpeg|jpg|png|svg|webp)$/i.test(file.name || '');
        };

        const uploadOneImage = (file, endpoint, onProgress) => new Promise((resolve, reject) => {
            const form = new FormData();
            form.append('file', file, file.webkitRelativePath || file.name);

            const request = new XMLHttpRequest();
            request.open('POST', endpoint);
            request.withCredentials = true;
            request.upload.onprogress = (event) => {
                if (event.lengthComputable) {
                    onProgress(event.loaded);
                }
            };
            request.onload = () => {
                if (request.status >= 200 && request.status < 300) {
                    resolve();
                    return;
                }

                reject(new Error(readUploadError(request)));
            };
            request.onerror = () => reject(new Error('Network error while uploading image.'));
            request.onabort = () => reject(new Error('Upload was aborted.'));
            request.send(form);
        });

        const readUploadError = (request) => {
            try {
                const body = JSON.parse(request.responseText || '{}');
                return body.error || `HTTP ${request.status}`;
            } catch {
                return request.responseText || `HTTP ${request.status}`;
            }
        };
    </script>
</body>
</html>
