<Project Sdk="Microsoft.NET.Sdk">

    <Sdk Name="Aspire.AppHost.Sdk" Version="13.0.0"/>

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <IsAspireHost>true</IsAspireHost>
        <UserSecretsId>2acdf813-97a1-4c19-92fd-618b39668cb5</UserSecretsId>

        <AssemblyName>Aspire.AppHost</AssemblyName>
        <RootNamespace>Aspire</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Aspire.Hosting.AppHost"/>
        <PackageReference Include="Aspire.Hosting.PostgreSQL"/>
        <PackageReference Include="Aspire.Hosting.Docker"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\Common\Common.csproj" IsAspireProjectResource="false"/>
        <ProjectReference Include="..\..\Infrastructure\Infrastructure.csproj" IsAspireProjectResource="false"/>
        <ProjectReference Include="..\..\Tools\DeploySetup\DeploySetup.csproj" IsAspireProjectResource="false"/>
        <ProjectReference Include="..\Extensions\Extensions.csproj" IsAspireProjectResource="false"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\ConsoleGateway\ConsoleGateway.csproj" />
        <ProjectReference Include="..\Coordinator\Coordinator.csproj"/>
        <ProjectReference Include="..\MetaGateway\MetaGateway.csproj"/>
        <ProjectReference Include="..\Silo\Silo.csproj"/>
        <ProjectReference Include="..\..\Frontend\Server\Server.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <Content Update="Startup\NamedGrainStorage.sql">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <Content Update="Startup\PostgreSQL-Clustering.sql">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <Content Update="Startup\PostgreSQL-Clustering-3.7.0.sql">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <Content Update="Startup\PostgreSQL-Main.sql">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <Content Update="Startup\PostgreSQL-Persistence.sql">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <None Remove="Startup\NamedGrainStorage.sql"/>
        <None Remove="Startup\PostgreSQL-Clustering.sql"/>
        <None Remove="Startup\PostgreSQL-Clustering-3.7.0.sql"/>
        <None Remove="Startup\PostgreSQL-Main.sql"/>
        <None Remove="Startup\PostgreSQL-Persistence.sql"/>
        <Content Update="Startup\Queries\PostgreSQL-Clustering.sql">
          <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <Content Update="Startup\Queries\PostgreSQL-Persistence.sql">
          <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <Content Update="Startup\Queries\PostgreSQL-Main.sql">
          <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <Content Update="Startup\Queries\PostgreSQL-Clustering-3.7.0.sql">
          <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <Content Include="appsettings.local.json" Condition="Exists('ppsettings.local.json')">
            <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
            <Link>appsettings.local.json</Link>
        </Content>
    </ItemGroup>
</Project>
